        "jsCode": "// ================================================================\n// v3: VALIDATE & PREPARE LEAD DATA\n// Normalizes inputs, validates email, extracts domain metadata\n// Added: urgency signal, referral source, timeline scoring\n// ================================================================\nconst f = $json;\n\n// --- Extract & normalize\nconst name        = (f['What is your full name?'] || '').trim();\nconst email       = (f['What is your Email Address?'] || '').trim().toLowerCase();\nconst websiteRaw  = (f['What is your Website URL?'] || '').trim();\nconst companyName = (f['What is the name of your company?'] || '').trim();\nconst companySize = parseInt(f['What is your company size (number of employees)?'] || '0', 10);\nconst budget      = parseFloat(f['What is your monthly budget (USD)?'] || '0');\nconst problem     = (f['What problem are you trying to solve?'] || '').trim();\nconst referralSource = (f['How did you hear about us?'] || 'Unknown').trim();\nconst timeline    = (f['What is your timeline to get started?'] || 'Just exploring').trim();\n\n// --- Email validation\nconst emailRegex     = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nconst isValidEmail   = emailRegex.test(email);\nconst emailDomain    = email.includes('@') ? email.split('@')[1].toLowerCase() : '';\nconst personalDomains = ['gmail.com','yahoo.com','hotmail.com','outlook.com',\n                         'aol.com','icloud.com','protonmail.com','live.com','ymail.com'];\nconst isPersonalEmail = personalDomains.includes(emailDomain);\n\n// --- Normalize website URL\nlet normalizedUrl = websiteRaw;\nif (normalizedUrl && !/^https?:\\/\\//i.test(normalizedUrl)) {\n  normalizedUrl = 'https://' + normalizedUrl;\n}\n\n// --- Company domain (from email or URL)\nconst companyDomain = (!isPersonalEmail && emailDomain)\n  ? emailDomain\n  : (websiteRaw\n      ? websiteRaw.replace(/^https?:\\/\\//i,'').split('/')[0].replace(/^www\\./,'')\n      : 'unknown');\n\n// --- Timeline urgency signal\nconst isUrgent = timeline === 'Immediately (this week)' || timeline === 'Within 1 month';\nconst timelineScore = timeline === 'Immediately (this week)' ? 15\n  : timeline === 'Within 1 month' ? 10\n  : timeline === '1–3 months' ? 5 : 0;\n\n// --- Data quality score\nlet dqScore = 0;\nif (isValidEmail)        dqScore += 20;\nif (!isPersonalEmail)    dqScore += 20;\nif (companyName)         dqScore += 20;\nif (normalizedUrl)       dqScore += 20;\nif (problem.length > 20) dqScore += 20;\nconst dataQuality = dqScore >= 80 ? 'Complete' : dqScore >= 40 ? 'Partial' : 'Incomplete';\n\n// --- Pass everything forward\nreturn {\n  name,\n  email,\n  companyName,\n  companySize,\n  budget,\n  problem,\n  websiteRaw,\n  normalizedUrl,\n  referralSource,\n  timeline,\n  isUrgent,\n  timelineScore,\n  _meta: {\n    emailDomain,\n    isValidEmail,\n    isPersonalEmail,\n    companyDomain,\n    dataQuality,\n    sessionKey: email,\n    submittedAt: new Date().toISOString(),\n    leadSource: 'Web Form'\n  }\n};"
      },
