        "jsCode": "// ================================================================\n// v3: MERGE ENRICHED DATA\n// Combines website health result with lead data\n// ================================================================\nconst leadData = $('Validate & Prepare Data').item.json;\nconst httpItem = $json;\n\nlet websiteStatus = 'Unreachable';\nlet isLive = false;\n\ntry {\n  const sc = httpItem.statusCode || httpItem.status;\n  if (sc && sc >= 200 && sc < 400) {\n    websiteStatus = 'Live (HTTP ' + sc + ')';\n    isLive = true;\n  } else if (sc) {\n    websiteStatus = 'Error (HTTP ' + sc + ')';\n  } else if (httpItem && !httpItem.error) {\n    websiteStatus = 'Live';\n    isLive = true;\n  }\n} catch(e) {\n  websiteStatus = 'Unreachable';\n}\n\nreturn {\n  ...leadData,\n  _websiteCheck: {\n    status: websiteStatus,\n    isLive\n  }\n};"
